PORT=3001
DATABASE_URL=postgresql://postgres:password@localhost:5432/hr_system_demo
JWT_SECRET=your-super-secret-jwt-key-change-in-production
QR_SECRET=your-qr-signing-secret-change-in-production
JWT_EXPIRES_IN=8h
QR_TOKEN_TTL=60

# Local dev: http://localhost:5173 (Vite) or http://localhost:8080 (Docker)
# Production: set to your Vercel frontend URL, e.g. https://hr-system-demo.vercel.app
CORS_ORIGIN=http://localhost:5173

# Set to "true" to wipe the database and re-seed on next startup (Railway demo reset)
# FORCE_SEED=true
